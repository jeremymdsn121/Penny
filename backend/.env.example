# Copy to .env and fill in. NEVER commit the real .env.

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- FastAPI ----
ENV=development
SECRET_KEY=change-me
# Public base URL of this backend (used to build absolute consent links).
PUBLIC_BASE_URL=http://localhost:8000

# ---- AI / extraction ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=            # Whisper transcription for WhatsApp voice memos

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@usepenny.ai
# Section 4 — inbound reply threading. Domain whose MX points to mx.sendgrid.net;
# outbound mail sets Reply-To: tx-{id}@<this domain>. Leave blank to disable.
REPLY_EMAIL_DOMAIN=
# Shared secret for the SendGrid Inbound Parse webhook (?key=...). Leave blank in dev.
SENDGRID_WEBHOOK_KEY=

# ---- Twilio (WhatsApp + SMS) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # sandbox or production WhatsApp sender
TWILIO_SMS_FROM=                              # Section 1C — standard SMS number (+1XXXXXXXXXX)
TWILIO_SKIP_VALIDATION=false                  # true only in local dev behind ngrok

# ---- Market data ----
RENTCAST_API_KEY=

# ---- AI disclosure consent (Section 6) ----
CONSENT_SECRET=            # HMAC secret for consent links; falls back to SECRET_KEY

# ---- Deferred integrations (not wired yet — see BLOCKERS.md) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
REDIS_URL=
# DocuSign (Section 8) — needs a developer account + integration key + partner review.
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
